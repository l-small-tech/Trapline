#!/usr/bin/env bash
# Trapline launcher: build, install as a systemd user service, and manage it.
# Falls back to nohup+pidfile when no systemd user session is available.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PORT="${TRAPLINE_PORT:-8731}"
HEALTH_URL="http://127.0.0.1:${PORT}/trapline/api/health"
UNIT_NAME="trapline"
UNIT_FILE="$HOME/.config/systemd/user/${UNIT_NAME}.service"
RUN_DIR="$ROOT/.run"
PID_FILE="$RUN_DIR/trapline.pid"
LOG_FILE="/tmp/trapline-server.log"

# Make sure nvm-installed node is on PATH even from a bare shell/cron.
if ! command -v node >/dev/null 2>&1 && [ -s "$HOME/.nvm/nvm.sh" ]; then
    # shellcheck disable=SC1091
    . "$HOME/.nvm/nvm.sh"
fi

say()  { printf '\033[1;36m[trapline]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[trapline]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[trapline]\033[0m %s\n' "$*" >&2; exit 1; }

have_user_systemd() {
    command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1
}

unit_installed() {
    [ -f "$UNIT_FILE" ]
}

wait_healthy() {
    local tries="${1:-30}"
    for _ in $(seq "$tries"); do
        if curl -fsS --max-time 2 "$HEALTH_URL" >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
    done
    return 1
}

cmd_build() {
    command -v node >/dev/null 2>&1 || die "node not found — install Node 22+ (nvm recommended)"
    say "node $(node --version) / npm $(npm --version)"
    say "installing dependencies…"
    (cd "$ROOT" && npm install)
    say "checking better-sqlite3 native module…"
    (cd "$ROOT" && node -e "require('better-sqlite3')(':memory:').exec('select 1')") || die \
        "better-sqlite3 failed to load. Try: sudo apt install build-essential python3 && rm -rf node_modules && ./trapline build"
    say "typechecking…"
    (cd "$ROOT" && npm run typecheck)
    say "running tests…"
    (cd "$ROOT" && npm test)
    say "building web UI…"
    (cd "$ROOT" && npm run build:web)
    say "build complete ✓"
}

cmd_setup() {
    local node_bin
    node_bin="$(readlink -f "$(command -v node)")" || die "node not found"
    mkdir -p "$(dirname "$UNIT_FILE")"
    sed -e "s|__ROOT__|$ROOT|g" -e "s|__NODE__|$node_bin|g" \
        "$ROOT/deploy/trapline.service.tmpl" > "$UNIT_FILE"
    say "installed $UNIT_FILE"

    if have_user_systemd; then
        systemctl --user daemon-reload
        systemctl --user enable "$UNIT_NAME" >/dev/null 2>&1 || true
        say "service enabled (starts on login)"
        if loginctl enable-linger "$USER" 2>/dev/null; then
            say "lingering enabled — Trapline will start at boot even before login"
        else
            warn "could not enable lingering automatically; for start-at-boot run:"
            warn "  sudo loginctl enable-linger $USER"
        fi
    else
        warn "no systemd user session detected — 'start' will use the nohup fallback"
    fi

    cat <<EOF

Next steps to serve Trapline through nginx at http://<this-host>/trapline/ :

  1. Add this line inside the server { } block of /etc/nginx/sites-available/default:
       include $ROOT/deploy/nginx-trapline.conf;
  2. Give nginx read access to the web build:
       sudo setfacl -R -m u:www-data:rX $ROOT/web/dist
  3. Test and reload nginx:
       sudo nginx -t && sudo systemctl reload nginx

(The app also works without nginx at http://127.0.0.1:${PORT}/trapline/)
EOF
}

cmd_start() {
    if have_user_systemd && unit_installed; then
        systemctl --user start "$UNIT_NAME"
    else
        warn "using nohup fallback (run './trapline setup' for the systemd service)"
        mkdir -p "$RUN_DIR"
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            say "already running (pid $(cat "$PID_FILE"))"
            return 0
        fi
        (cd "$ROOT" && nohup node node_modules/.bin/tsx server/src/index.ts >"$LOG_FILE" 2>&1 &
         echo $! > "$PID_FILE")
    fi
    if wait_healthy 30; then
        say "up ✓  $HEALTH_URL"
        say "dashboard: http://127.0.0.1:${PORT}/trapline/"
    else
        die "did not become healthy — check './trapline logs'"
    fi
}

cmd_stop() {
    if have_user_systemd && unit_installed; then
        systemctl --user stop "$UNIT_NAME"
    elif [ -f "$PID_FILE" ]; then
        kill "$(cat "$PID_FILE")" 2>/dev/null || true
        rm -f "$PID_FILE"
    fi
    say "stopped"
}

cmd_status() {
    if have_user_systemd && unit_installed; then
        systemctl --user --no-pager status "$UNIT_NAME" || true
    elif [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        say "running via nohup (pid $(cat "$PID_FILE"))"
    else
        say "not running"
    fi
    echo
    if curl -fsS --max-time 2 "$HEALTH_URL" 2>/dev/null; then
        echo
        curl -fsS --max-time 2 "http://127.0.0.1:${PORT}/trapline/api/status" 2>/dev/null \
            | node -e "let d='';process.stdin.on('data',c=>d+=c).on('end',()=>{const s=JSON.parse(d);console.log('state: '+s.state+' | mode: '+s.mode+' | targets: '+s.targets.map(t=>t.target.host+(t.lastRttMs!==null?' '+t.lastRttMs.toFixed(1)+'ms':' n/a')).join(', '))})" 2>/dev/null || true
    else
        warn "health endpoint not answering on port ${PORT}"
    fi
}

cmd_logs() {
    if have_user_systemd && unit_installed; then
        journalctl --user -u "$UNIT_NAME" -f --no-pager -n 100
    else
        tail -n 100 -f "$LOG_FILE"
    fi
}

cmd_mode() {
    local mode="${1:-}"
    case "$mode" in
        eco|normal|full) ;;
        *) die "usage: ./trapline mode eco|normal|full" ;;
    esac
    curl -fsS -X POST -H 'content-type: application/json' \
        -d "{\"mode\":\"$mode\"}" "http://127.0.0.1:${PORT}/trapline/api/mode" >/dev/null \
        && say "mode set to $mode" || die "could not reach the server"
}

case "${1:-help}" in
    build)   cmd_build ;;
    setup)   cmd_setup ;;
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_stop; sleep 1; cmd_start ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    mode)    shift; cmd_mode "${1:-}" ;;
    *)
        cat <<'EOF'
Trapline — ISP quality monitor

Usage: ./trapline <command>

  build     Install dependencies, typecheck, test, and build the web UI
  setup     Install + enable the systemd user service and print nginx steps
  start     Start monitoring (systemd service, or nohup fallback)
  stop      Stop monitoring
  restart   Stop then start
  status    Service state + live health/mode/targets
  logs      Follow the server logs
  mode      Switch monitoring mode: ./trapline mode eco|normal|full

Quick start:  ./trapline build && ./trapline setup && ./trapline start
EOF
        ;;
esac
